<?xml version="1.0"?>
<registry>

  <records
    interface="Products.CMFPlone.interfaces.IBundleRegistry"
    prefix="plone.bundles/upc-bundle">

    <value key="enabled">True</value>
    <value key="compile">True</value>
    <value key="resources">
      <element>upc-main</element>
    </value>
    <value key="jscompilation" />
    <value key="csscompilation">++theme++genweb6.upc/stylesheets/theme-upc.min.css</value>

  </records>

  <!-- folder_contents (pat-structure): plone.icon.contenttype mas portal type normalizado -->
  <record name="plone.icon.contenttype/packet">
    <field type="plone.registry.field.TextLine">
      <title>UPC packet</title>
    </field>
    <value key="resource">++plone++bootstrap-icons/box.svg</value>
  </record>

</registry>
